# Umami analytics — production only (leave unset locally).
# These are PUBLIC_-prefixed because Astro/Vite needs to bake them into
# the static build output. In Coolify they MUST be set as Build Variable,
# NOT Runtime — the static build inlines them at build time.
PUBLIC_UMAMI_SRC=https://umami.sinapsys.work/script.js
PUBLIC_UMAMI_WEBSITE_ID=<uuid-from-umami-dashboard>
