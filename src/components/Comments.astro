---
import {
  GISCUS_REPO,
  GISCUS_REPO_ID,
  GISCUS_CATEGORY,
  GISCUS_CATEGORY_ID,
} from "../lib/giscus.ts";
---

<section
  class="max-w-3xl mx-auto px-6 mt-12 pt-10 border-t pb-24"
  style="border-color: var(--color-border-subtle);"
  aria-label="Comentarios"
>
  <header class="mb-8">
    <p
      class="text-sm mb-2"
      style="font-family: var(--font-mono); color: var(--color-fg-muted);"
    >
      <span style="color: var(--color-fg-dim);">$</span> echo "comentarios"
    </p>
    <h2
      class="text-2xl md:text-3xl font-bold mb-3 tracking-tight"
      style="color: var(--color-fg-primary);"
    >
      <span
        style="font-family: var(--font-mono); color: var(--color-fg-dim); font-size: 0.7em;"
        >## </span
      >Discusión
    </h2>
    <p
      class="text-sm leading-relaxed max-w-[60ch]"
      style="color: var(--color-fg-muted);"
    >
      Comentarios via <a
        href="https://github.com/danielmiralles/personalsite/discussions"
        target="_blank"
        rel="noopener"
        class="link-underline"
        style="color: var(--color-accent);">GitHub Discussions</a
      >. Necesitas una cuenta de GitHub para participar.
    </p>
  </header>

  <script
    is:inline
    src="https://giscus.app/client.js"
    data-repo={GISCUS_REPO}
    data-repo-id={GISCUS_REPO_ID}
    data-category={GISCUS_CATEGORY}
    data-category-id={GISCUS_CATEGORY_ID}
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="dark_dimmed"
    data-lang="es"
    data-loading="lazy"
    crossorigin="anonymous"
    async></script>
</section>
