---
import { slugify } from "../lib/slug.ts";

interface Props {
  name: string;
  href?: string;
}

const { name, href } = Astro.props;

// Default: link to /tags/<slug>. Passing href explicitly overrides this.
const finalHref = href ?? `/tags/${slugify(name)}`;

const baseClass =
  "inline-block text-xs px-2.5 py-1 rounded transition-colors";
const baseStyle =
  "font-family: var(--font-mono); background-color: var(--color-accent-soft); color: var(--color-accent);";
---

<a class={baseClass} style={baseStyle} href={finalHref}>#{name}</a>
