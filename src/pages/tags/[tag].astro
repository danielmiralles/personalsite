---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SearchableCards from "../../components/SearchableCards.astro";
import { slugify } from "../../lib/slug.ts";

type CollectionName = "posts" | "playbooks" | "pildoras";
type ContentType = "post" | "playbook" | "pildora";
type AnyEntry =
  | CollectionEntry<"posts">
  | CollectionEntry<"playbooks">
  | CollectionEntry<"pildoras">;

const collectionToType: Record<CollectionName, ContentType> = {
  posts: "post",
  playbooks: "playbook",
  pildoras: "pildora",
};

export async function getStaticPaths() {
  const [posts, playbooks, pildoras] = await Promise.all([
    getCollection("posts", ({ data }) => !data.draft),
    getCollection("playbooks", ({ data }) => !data.draft),
    getCollection("pildoras", ({ data }) => !data.draft),
  ]);
  const all = [...posts, ...playbooks, ...pildoras];

  const buckets = new Map<string, { tag: string; entries: typeof all }>();
  for (const entry of all) {
    for (const tag of entry.data.tags) {
      const slug = slugify(tag);
      const existing = buckets.get(slug);
      if (existing) {
        existing.entries.push(entry);
      } else {
        buckets.set(slug, { tag, entries: [entry] });
      }
    }
  }

  return Array.from(buckets.entries()).map(([slug, { tag, entries }]) => ({
    params: { tag: slug },
    props: { tag, entries },
  }));
}

const { tag, entries } = Astro.props as {
  tag: string;
  entries: AnyEntry[];
};

const sorted = [...entries].sort((a, b) => +b.data.date - +a.data.date);

const dateFmt = new Intl.DateTimeFormat("es-ES", {
  year: "numeric",
  month: "short",
  day: "2-digit",
});

const items = sorted.map((entry) => ({
  type: collectionToType[entry.collection as CollectionName],
  title: entry.data.title,
  excerpt: entry.data.excerpt,
  date: dateFmt.format(entry.data.date),
  readTime: entry.data.readTime,
  tags: entry.data.tags,
  href: `/${entry.collection}/${entry.id}`,
}));

const title = `#${tag} — Daniel Miralles`;
const description = `Posts, playbooks y píldoras etiquetados como "${tag}".`;
---

<Layout title={title} description={description}>
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-10">
    <p
      class="text-sm mb-4"
      style="font-family: var(--font-mono); color: var(--color-fg-muted);"
    >
      <a
        href="/tags"
        class="link-underline"
        style="color: var(--color-fg-muted);"
      >
        <span style="color: var(--color-fg-dim);">$ cd ~/tags/</span>{tag}
      </a>
    </p>
    <h1
      class="text-4xl md:text-5xl font-bold mb-4 tracking-tight"
      style="color: var(--color-fg-primary);"
    >
      <span style="color: var(--color-accent);">#</span>{tag}
    </h1>
    <p
      class="text-lg max-w-[60ch] leading-relaxed"
      style="color: var(--color-fg-muted);"
    >
      {items.length} entrada{items.length === 1 ? "" : "s"} sobre <span
        style="color: var(--color-accent);">{tag}</span>.
    </p>
  </section>

  <section class="max-w-5xl mx-auto px-6 pb-24">
    <SearchableCards items={items} searchPlaceholder={`buscar dentro de #${tag}…`} />
  </section>
</Layout>
